ARG RUNTIME_BASE=debian:bookworm-slim
FROM golang:1.25-bookworm AS build

ARG TAGMEM_VERSION=dev
ARG TARGETARCH=amd64

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN case "$TARGETARCH" in \
      amd64|arm64) ;; \
      *) \
        echo "linux/$TARGETARCH is not supported for runtime images" >&2; \
        exit 1; \
        ;; \
    esac && \
    CGO_ENABLED=1 GOOS=linux GOARCH=$TARGETARCH go build -tags tagmem_onnx -buildvcs=false -trimpath -ldflags="-s -w -X github.com/codysnider/tagmem/internal/buildinfo.Version=${TAGMEM_VERSION}" -o /out/tagmem ./cmd/tagmem

FROM ${RUNTIME_BASE}

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
 && rm -rf /var/lib/apt/lists/*

COPY --from=build /out/tagmem /usr/local/bin/tagmem

ENTRYPOINT ["/usr/local/bin/tagmem"]
